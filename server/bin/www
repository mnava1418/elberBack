#!/usr/bin/env node

const debug = require('debug')('elber:server');
const fs = require('fs');
const http = require('http');
const https = require('https');
const mongoose = require('mongoose');
const app = require('../app');
const mongooseLoader = require('../loaders/mongooseLoader');
const socketIOLoader = require('../loaders/socketIOLoader');

var httpServer = undefined;
var httpsServer = undefined
const env = app.get('env');
console.log(env)

async function startServer () {
  const port = normalizePort(process.env.PORT || '80');
  app.set('port', port);

  //HTTP
  httpServer = await http.createServer(app)
  httpServer.listen(port, (err) => {
    if (err) {
      console.log(err);
      return;
    }
    console.log(`Server listening on port: ${port}...`);
    //Moongose Loader
    mongooseLoader(env);

    //SocketIO Loader
    socketIOLoader(httpServer);
  });

  httpServer.on('error', onError);
  //End HTTP

  //HTTPS
  // Certificate
  const privateKey = fs.readFileSync('/etc/letsencrypt/live/elberdrops.com/privkey.pem', 'utf8');
  const certificate = fs.readFileSync('/etc/letsencrypt/live/elberdrops.com/cert.pem', 'utf8');
  const ca = fs.readFileSync('/etc/letsencrypt/live/elberdrops.com/chain.pem', 'utf8');

  const credentials = {
    key: privateKey,
    cert: certificate,
    ca: ca
  };

  app.set('port', 443);
  httpsServer = await https.createServer(credentials, app)
  httpsServer.listen(443, (err) => {
    if (err) {
      console.log(err);
      return;
    }
    console.log(`Server listening on port: 443...`);
    //Moongose Loader
    mongooseLoader(env);

    //SocketIO Loader
    socketIOLoader(httpsServer);
  });

  httpsServer.on('error', onError);
  //End HTTPS
}

//Normalize a port into a number, string, or false.
function normalizePort(val) {
  const port = parseInt(val, 10);

  if (isNaN(port)) {
    return val;
  }

  if (port >= 0) {
    return port;
  }

  return false;
}

//Event listener for HTTPS server "error" event.
function onError(error) {
  if (error.syscall !== 'listen') {
  throw error;
  }

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

process.on('SIGINT', async () => {
  console.log('Stoping server...');
  mongoose.disconnect((err) => {
    if(err) {
        console.log(err)
    }else {
        console.log('Mongo connection closed')
        process.exit(0);
    }
  })
})

startServer();
