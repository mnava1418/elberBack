#!/usr/bin/env node

const debug = require('debug')('elber:server');
const fs = require('fs');
const http = require('http');
const https = require('https');
const express = require('express')
const mongoose = require('mongoose');
const app = require('../app');
const mongooseLoader = require('../loaders/mongooseLoader');
const socketIOLoader = require('../loaders/socketIOLoader');

const env = app.get('env');
console.log(env)

const startHttpServer = async () => {
  const httpApp = express()
  httpApp.get('*', (req, res) => {
    res.redirect(`https://${req.headers.host}${req.url}`)
  })
  
  const httpServer = await http.createServer(httpApp)
  httpServer.listen(80, (err) => {
    if(err) {
      console.log(err)
    } else {
      console.log('Http Server listening on port: 80')
    }
  })
}

const startHttpsServer = async () => {
  // Certificate
  const privateKey = fs.readFileSync('/etc/letsencrypt/live/elberdrops.com/privkey.pem', 'utf8');
  const certificate = fs.readFileSync('/etc/letsencrypt/live/elberdrops.com/cert.pem', 'utf8');
  const ca = fs.readFileSync('/etc/letsencrypt/live/elberdrops.com/chain.pem', 'utf8');

  const credentials = {
    key: privateKey,
    cert: certificate,
    ca: ca
  };

  app.set('port', port);
  const httpsServer = await https.createServer(credentials, app)
  httpsServer.listen(port, (err) => {
    if (err) {
      console.log(err);
      return;
    }
    console.log(`Https Server listening on port: ${port}...`);
    //Moongose Loader
    mongooseLoader(env);

    //SocketIO Loader
    socketIOLoader(httpsServer);
  });

  httpsServer.on('error', onError);
}

//Normalize a port into a number, string, or false.
const normalizePort = (val) => {
  const port = parseInt(val, 10);

  if (isNaN(port)) {
    return val;
  }

  if (port >= 0) {
    return port;
  }

  return false;
}

//Event listener for HTTPS server "error" event.
const onError = (error) => {
  if (error.syscall !== 'listen') {
  throw error;
  }

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(`${port} requires elevated privileges`);
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(`${port} is already in use`);
      process.exit(1);
      break;
    default:
      throw error;
  }
}

process.on('SIGINT', async () => {
  console.log('Stoping server...');
  mongoose.disconnect((err) => {
    if(err) {
        console.log(err)
    }else {
        console.log('Mongo connection closed')
        process.exit(0);
    }
  })
})

let port = normalizePort(process.env.PORT || '443');
startHttpServer()
startHttpsServer();
