head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  link(rel='icon' type='image/png' href='/images/icons/elberIcon.ico')
  // ===============================================================================================
  link(rel='stylesheet' type='text/css' href='/fonts/iconic/css/material-design-iconic-font.min.css')
  // ===============================================================================================
  link(rel='stylesheet' type='text/css' href='/css/util.css')
  link(rel='stylesheet' type='text/css' href='/css/login.css')
  // ===============================================================================================
  title Elber Drops
.main-top
  .main-login
    .login-logo
      .logo-content
      span.login100-form-title.p-b-26 Elber
    .login-form
      .login100-form.validate-form
        .wrap-input100.validate-input(data-validate='Valid email is: a@b.c')
          input#user-email.input100(type='text' name='email')
          span.focus-input100(data-placeholder='Email')
        .wrap-input100.validate-input(data-validate='Enter password')
          span.btn-show-pass
            i.zmdi.zmdi-eye
          input#user-password.input100(type='password' name='pass')
          span.focus-input100(data-placeholder='Password')
        .container-login100-form-btn
          .wrap-login100-form-btn
            .login100-form-bgbtn
            button.login100-form-btn
              | Login
    .login-footer
.main-bottom
// ===============================================================================================
script(src='/js/vendor/jquery/jquery-3.2.1.min.js')
// ===============================================================================================
script(src='/js/vendor/bootstrap/js/popper.js')
script(src='/js/vendor/bootstrap/js/bootstrap.min.js')
// ===============================================================================================
script(src='/js/login.js')
